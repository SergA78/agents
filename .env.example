# =============================================================================
# Competitor Intelligence Agent — пример переменных окружения
# Скопируйте этот файл в .env и подставьте свои значения.
# =============================================================================

# ── LLM-провайдер (OpenAI / Ollama) ──────────────────────────────────────────
# Провайдеры выбираются НЕЗАВИСИМО для чата и для эмбеддингов: можно использовать
# OpenAI и Ollama по отдельности или вместе (например, чат через Ollama,
# эмбеддинги через OpenAI). Допустимые значения: openai | ollama.
CHAT_PROVIDER=openai   # openai | ollama — какой провайдер использовать для чата/анализа
EMBEDDING_PROVIDER=openai   # openai | ollama — какой провайдер использовать для эмбеддингов
# Параметры Ollama (используются, когда соответствующий *_PROVIDER=ollama).
# Ollama предоставляет OpenAI-совместимый API на {host}:11434/v1.
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_API_KEY=ollama   # Ollama игнорирует ключ, но OpenAI SDK требует непустое значение
OLLAMA_MODEL=llama3.1   # модель чата в Ollama (нужно заранее: ollama pull llama3.1)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text   # модель эмбеддингов в Ollama (ollama pull nomic-embed-text)

# ── LLM (OpenAI-совместимый API) ─────────────────────────────────────────────
# Ключ доступа к провайдеру LLM (OpenAI / любой OpenAI-совместимый сервис)
OPENAI_API_KEY=sk-your-key-here
# Базовый URL провайдера. Для официального OpenAI оставьте значение по умолчанию,
# для других провайдеров укажите их endpoint (например, https://openrouter.ai/api/v1)
OPENAI_BASE_URL=https://api.openai.com/v1
# Модель для генерации текста / анализа
OPENAI_MODEL=gpt-4o-mini
# Модель для построения эмбеддингов (RAG)
EMBEDDING_MODEL=text-embedding-3-small
# Размерность векторов эмбеддингов. ДОЛЖНА совпадать с выбранной моделью
# эмбеддингов: для text-embedding-3-small = 1536, для nomic-embed-text = 768.
# При смене провайдера эмбеддингов установите корректное значение и ПЕРЕСОЗДАЙТЕ
# БД (удалите том pgdata), т.к. размерность вектора фиксируется при создании схемы.
EMBEDDING_DIM=1536

# ── База данных (PostgreSQL + pgvector) ──────────────────────────────────────
# Пользователь БД приложения
POSTGRES_USER=ci_agent
# Пароль пользователя БД приложения
POSTGRES_PASSWORD=ci_agent_pass
# Имя базы данных приложения
POSTGRES_DB=ci_agent
# Хост БД (имя сервиса в docker-compose)
POSTGRES_HOST=postgres
# Порт БД
POSTGRES_PORT=5432
# Полный URL подключения (используется приложением через SQLAlchemy + psycopg)
DATABASE_URL=postgresql+psycopg://ci_agent:ci_agent_pass@postgres:5432/ci_agent

# ── SearXNG (веб-поиск) ──────────────────────────────────────────────────────
# URL экземпляра SearXNG (имя сервиса в docker-compose). Приложение обращается
# к нему по HTTP API и ожидает ответ в формате JSON.
SEARXNG_URL=http://searxng:8080

# ── Langfuse (трассировка / наблюдаемость) ───────────────────────────────────
# Публичный ключ проекта Langfuse (создаётся в UI после первого запуска)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
# Секретный ключ проекта Langfuse
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
# Хост Langfuse (имя сервиса в docker-compose)
LANGFUSE_HOST=http://langfuse-web:3000

# ── Приложение ───────────────────────────────────────────────────────────────
# Список отслеживаемых компаний (через запятую)
COMPANIES=Apple,Microsoft
# Глубина первичного сбора данных в днях (seed)
SEED_DAYS=30
# Интервал периодического сбора данных в часах
COLLECT_INTERVAL_HOURS=6
# Порт, на котором публикуется приложение наружу
APP_PORT=8000
# Уровень логирования (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
